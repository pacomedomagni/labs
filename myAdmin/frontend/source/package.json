{
  "name": "admin",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "ngversion": "ng version",
    "start": "ng serve --open",
    "start-debug": "ng serve --port 4200",
    "build": "ng build",
    "build:prod": "npm run lint && node ./node_modules/@angular/cli/bin/ng build --configuration=production && npm run test:coverage",
    "test": "jest --config ./jest.config.js",
    "test:watch": "jest -o --watch --config ./jest.config.js",
    "test:debug": "node --inspect-brk ./node_modules/jest/bin/jest.js --runInBand --config ./jest.config.js",
    "test:coverage": "jest --coverage --config ./jest.config.js",
    "test:config": "jest  --showConfig",
    "lint": "eslint -c .eslintrc.json --parser-options=project:tsconfig.json --ext .ts ./src/app",
    "lint-fix": "eslint -c .eslintrc.json --parser-options=project:tsconfig.json --ext .ts ./src/app/ --fix",
    "e2e": "ng e2e"
  },
  "pre-commit": [
    "lint",
    "test"
  ],
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.16",
    "@angular/cdk": "^20.2.0",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/google-maps": "20.1.3",
    "@angular/material": "^20.2.0",
    "@angular/material-luxon-adapter": "^20.2.0",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@ngneat/until-destroy": "^9.0.0",
    "@ngrx/effects": "^20.0.0",
    "@ngrx/router-store": "^20.0.0",
    "@ngrx/store": "^20.0.0",
    "@ngrx/store-devtools": "^20.0.0",
    "@openid/appauth": "~1.3.0",
    "@pgr-cla/core-ui-components": "^34.8.0",
    "@splunk/otel-web": "^1.1.1",
    "admin": "file:",
    "angular-in-memory-web-api": "^0.20.0",
    "angular-oauth2-oidc": "^13.0.0",
    "branch-naming-check": "^1.0.2",
    "clone": "^2.0.0",
    "cross-spawn": "7.0.6",
    "eslint-plugin-jest": "29.0.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "file-saver": "^2.0.5",
    "form-data": "^4.0.4",
    "jest-runner": "30.1.1",
    "moment": "^2.0.0",
    "moment-timezone": "~0.5.0",
    "ngx-cookie-service": "20.1.0",
    "node-forge": "^1.3.2",
    "rxjs": "^7.0.0",
    "tslib": "^2.0.0",
    "vkbeautify": "^0.99.3",
    "webpack-dev-middleware": "^7.1.1",
    "xng-breadcrumb": "^8.0.0",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.7",
    "@angular-eslint/eslint-plugin": "20.1.1",
    "@angular-eslint/eslint-plugin-template": "20.1.1",
    "@angular-eslint/schematics": "20.1.1",
    "@angular-eslint/template-parser": "20.1.1",
    "@angular/build": "^20.3.7",
    "@angular/cli": "^20.3.7",
    "@angular/compiler-cli": "^20.3.7",
    "@types/jest": "^29.5.0",
    "@types/node": "^12.20.55",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/eslint-plugin-tslint": "7.0.2",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.44.0",
    "eslint-plugin-import": "^2.28.0",
    "eslint-plugin-jsdoc": "^39.9.1",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-html-reporter": "^4.3.0",
    "jest-junit": "^16.0.0",
    "jest-mock-extended": "^4.0.0",
    "jest-preset-angular": "^14.0.0",
    "ng-packagr": "^20.1.0",
    "postcss": "^8.0.0",
    "scuri": "^1.0.0",
    "tailwindcss": "^3.0.0",
    "ts-jest": "29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "5.8.3"
  },
  "overrides": {
    "qs": "6.14.1",
    "@angular/cli": {
      "@modelcontextprotocol/sdk": "1.25.2"
    },
     "tar": "^7.5.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run test:coverage",
      "pre-push": "branch-naming-check '^(feature|hotfix|release)/[a-z0-9][a-z0-9\\-]*[a-z0-9]$'"
    }
  }
}
